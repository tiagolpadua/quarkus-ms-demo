# Top-most EditorConfig file
root = true

# Global settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Java files
[*.java]
indent_style = space
indent_size = 4
continuation_indent_size = 8
max_line_length = 120

# YAML, JSON, XML (common in Java projects)
[*.{yml,yaml,json,xml}]
indent_size = 2

# Properties files (Spring, etc.)
[*.properties]
indent_size = 2

# Markdown files (docs)
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_size = 2

# Windows batch files
[*.bat]
end_of_line = crlf

# Makefiles (must use tabs)
[Makefile]
indent_style = tab

# Ignore minified files
[*.min.*]
indent_size = unset
